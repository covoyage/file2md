{
  "name": "@covoyage/file2md",
  "version": "1.0.0",
  "description": "Convert various file formats to Markdown for LLMs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "file2md": "./dist/cli.cjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "fixtures:generate": "GENERATE_FIXTURES=1 vitest run tests/fixtures/generate-fixtures.test.ts",
    "vectors:sync": "SYNC_PYTHON_VECTORS=1 vitest run tests/fixtures/sync-python-vectors.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/covoyage/file2md.git"
  },
  "homepage": "https://github.com/covoyage/file2md#readme",
  "bugs": {
    "url": "https://github.com/covoyage/file2md/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "markdown",
    "file-converter",
    "document",
    "llm",
    "pdf",
    "docx",
    "xlsx",
    "html",
    "svelte"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12",
    "mammoth": "^1.9.0",
    "turndown": "^7.2.0",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "@azure/ai-content-understanding": "^1.2.0-beta.1",
    "@azure/core-auth": "^1.9.0",
    "@azure/identity": "^4.8.0",
    "@kenjiuno/msgreader": "^1.23.0",
    "jschardet": "^3.1.4",
    "magika": "^1.0.0",
    "pdfjs-dist": "^4.10.38",
    "youtube-transcript-plus": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/turndown": "^5.0.5",
    "file2md-sample-plugin": "file:tests/plugins/file2md-sample-plugin",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "sideEffects": false
}
